# Variáveis de Ambiente - Backend

# Porta do servidor
PORT=10000

# URL de conexão com o MongoDB
# Exemplo para MongoDB Atlas:
# mongodb+srv://usuario:senha@cluster.mongodb.net/tododb
MONGODB_URL=mongodb://localhost:27017/todoapp

# URL do Frontend para CORS
# Em desenvolvimento: deixe vazio ou use *
# Em produção: use a URL exata do seu frontend
CORS_ORIGIN=*

# Ambiente
NODE_ENV=development
